# =============================================================================
# Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values.
# IMPORTANT: Never commit .env files with credentials to version control.
# =============================================================================

# --- API CONFIGURATION ---
# For local development with JSON Server (runs on port 4000 — see server.js /
# baseURL.js. 4000 is chosen so a drifting CRA dev server can never land on the
# API port and serve HTML instead of JSON):
REACT_APP_API_URL=http://localhost:4000
REACT_APP_USE_MOCK_API=true

# For production with Laravel API (update only the base URL):
# REACT_APP_API_URL=https://your-laravel-api.com/api/v1
# REACT_APP_USE_MOCK_API=false

# --- APP INFO (update for each project) ---
REACT_APP_NAME=North East Build Mart
REACT_APP_VERSION=1.0.0

# --- FEATURES ---
REACT_APP_ENABLE_ANALYTICS=false
GENERATE_SOURCEMAP=true

# --- PAYMENT GATEWAYS (production only) ---
# REACT_APP_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
# REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx

# --- SHIPPING (production only) ---
# REACT_APP_SHIPROCKET_EMAIL=admin@yourstore.com
