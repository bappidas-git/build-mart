# =============================================================================
# Development Environment Configuration
# =============================================================================
#
# This is the LOCAL DEVELOPMENT config using JSON Server.
# When you're ready for production, update REACT_APP_API_URL to your
# Laravel API base URL and set REACT_APP_USE_MOCK_API=false.
#
# HOW TO SWITCH TO PRODUCTION:
#   1. Set REACT_APP_API_URL=https://your-laravel-api.com/api/v1
#   2. Set REACT_APP_USE_MOCK_API=false
#   3. Restart the dev server: npm start
#
# IMPORTANT: Never commit credentials to version control.
# =============================================================================

# API Configuration - JSON Server for local development
#
# The mock API runs on port 4000 (NOT 3001). This is deliberate: Create React
# App's dev server wants port 3000 and, when that port is already taken by a
# stale dev server, it silently DRIFTS to the next free port (3001, 3002, …).
# If the mock API sat on 3001, that drift would land the React app ON TOP of the
# API port — every /categories and /products request would then return the app's
# index.html instead of JSON, and the storefront would render a silently-empty
# catalog (no main-menu categories, no product cards). Port 4000 sits outside
# that sequential drift range, so the collision can't happen. Keep this in sync
# with server.js (JSON_SERVER_PORT default) and baseURL.js (MOCK_API_URL).
REACT_APP_API_URL=http://localhost:4000
REACT_APP_USE_MOCK_API=true

# App Information (update for each project)
REACT_APP_NAME=North East Build Mart
REACT_APP_VERSION=1.0.0

# Feature Flags
REACT_APP_ENABLE_ANALYTICS=false

# Build Configuration
GENERATE_SOURCEMAP=true

# Payment Gateway (for production - Razorpay)
# REACT_APP_RAZORPAY_KEY_ID=your_razorpay_key_id

# Shiprocket (for production)
# REACT_APP_SHIPROCKET_EMAIL=your_shiprocket_email
